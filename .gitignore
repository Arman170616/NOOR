# Environment variables - NEVER commit these
backend/.env
**/.env
**/.env.local
**/.env.production

# Python
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/*.egg-info/
backend/.pytest_cache/
backend/db.sqlite3

# Flutter
flutter_app/.dart_tool/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies
